WITH ALTAS AS
(
    SELECT
        A.PERIODO,
        A.ID_CNBV,
        A.TIPO_ALTA
    FROM R04C0430 A
    INNER JOIN R04C0431 S
        ON S.PERIODO=A.PERIODO
       AND S.ID_CNBV=A.ID_CNBV
    WHERE A.TIPO_ALTA IN (...)
)

SELECT
    A.*
FROM ALTAS A
LEFT JOIN R04C0432 B
       ON B.PERIODO=A.PERIODO
      AND B.ID_CNBV=A.ID_CNBV
WHERE B.ID_CNBV IS NULL;
