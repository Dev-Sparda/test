--cc_003
WITH

UNIVERSO AS
(
    SELECT DISTINCT
        ID_CNBV
    FROM R04C0431
    WHERE PERIODO = :PERIODO
),

ULTIMA_ALTA AS
(
    SELECT
        A.ID_CNBV,
        A.PERIODO,
        A.TIPO_ALTA,
        ROW_NUMBER() OVER
        (
            PARTITION BY A.ID_CNBV
            ORDER BY A.PERIODO DESC
        ) AS RN
    FROM R04C0430 A
    INNER JOIN UNIVERSO U
        ON U.ID_CNBV = A.ID_CNBV
    WHERE A.PERIODO <= :PERIODO
      AND A.TIPO_ALTA IN
      (
        502,503,504,505,506,507,508,
        510,511,512,514,
        533,534,
        901,902,903,904,905,906,908,
        910,911,912,937
      )
),

ULTIMA_BAJA AS
(
    SELECT
        B.ID_CNBV,
        B.PERIODO,
        B.TIPO_BAJA,
        ROW_NUMBER() OVER
        (
            PARTITION BY B.ID_CNBV
            ORDER BY B.PERIODO DESC
        ) AS RN
    FROM R04C0432 B
    INNER JOIN UNIVERSO U
        ON U.ID_CNBV = B.ID_CNBV
    WHERE B.PERIODO <= :PERIODO
)

SELECT

    U.ID_CNBV,

    UA.PERIODO    AS PERIODO_ULTIMA_ALTA,
    UA.TIPO_ALTA,

    UB.PERIODO    AS PERIODO_ULTIMA_BAJA,
    UB.TIPO_BAJA

FROM UNIVERSO U

LEFT JOIN ULTIMA_ALTA UA
       ON UA.ID_CNBV = U.ID_CNBV
      AND UA.RN = 1

LEFT JOIN ULTIMA_BAJA UB
       ON UB.ID_CNBV = U.ID_CNBV
      AND UB.RN = 1

ORDER BY
    U.ID_CNBV;

--cc_0005
WITH

max_altas AS (

    SELECT
        RFC,
        MAX(PERIODO) AS PERIODO_ALTA
    FROM R04C0430
    WHERE T_ALTA = 501
      AND TIPO_CAR IN (330,340)
    GROUP BY RFC

),

ultima_alta AS (

    SELECT t.*

    FROM R04C0430 t
    JOIN max_altas m
      ON t.RFC = m.RFC
     AND t.PERIODO = m.PERIODO_ALTA

    WHERE t.T_ALTA = 501
      AND t.TIPO_CAR IN (330,340)

),

universo AS (

    SELECT DISTINCT RFC
    FROM ultima_alta

),

historial AS (

    SELECT
        h.*,
        u.PERIODO AS PERIODO_ALTA
    FROM R04C0430 h
    JOIN ultima_alta u
      ON h.RFC=u.RFC

),

auditoria AS (

    SELECT

        h.RFC,

        MIN(PERIODO) PRIMER_PERIODO,
        MAX(PERIODO) ULTIMO_PERIODO,

        h.PERIODO_ALTA,

        COUNT(DISTINCT PERIODO) PERIODOS_REPORTADOS,

        COUNT(*) TOTAL_APARICIONES,

        COUNT(DISTINCT NOMB_CLI) CNT_NOMBRE,
        COUNT(DISTINCT MUNI_CRED) CNT_MUNI,
        COUNT(DISTINCT LOC_CRED) CNT_LOC,
        COUNT(DISTINCT GPO_RIES) CNT_GPO,
        COUNT(DISTINCT ACT_ECO) CNT_ACT,
        COUNT(DISTINCT TIPO_CAR) CNT_TIPO,

        EXISTS(

            SELECT 1

            FROM R04C0431 s

            WHERE s.RFC=h.RFC
              AND s.PERIODO=h.PERIODO_ALTA

        ) TIENE_431

    FROM historial h

    GROUP BY
        RFC,
        PERIODO_ALTA

)
