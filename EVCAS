--cc_003
WITH

UNIVERSO AS
(
    SELECT DISTINCT
        ID_CNBV
    FROM R04C0431
    WHERE PERIODO = :PERIODO
),

ULTIMA_ALTA AS
(
    SELECT
        A.ID_CNBV,
        A.PERIODO,
        A.TIPO_ALTA,
        ROW_NUMBER() OVER
        (
            PARTITION BY A.ID_CNBV
            ORDER BY A.PERIODO DESC
        ) AS RN
    FROM R04C0430 A
    INNER JOIN UNIVERSO U
        ON U.ID_CNBV = A.ID_CNBV
    WHERE A.PERIODO <= :PERIODO
      AND A.TIPO_ALTA IN
      (
        502,503,504,505,506,507,508,
        510,511,512,514,
        533,534,
        901,902,903,904,905,906,908,
        910,911,912,937
      )
),

ULTIMA_BAJA AS
(
    SELECT
        B.ID_CNBV,
        B.PERIODO,
        B.TIPO_BAJA,
        ROW_NUMBER() OVER
        (
            PARTITION BY B.ID_CNBV
            ORDER BY B.PERIODO DESC
        ) AS RN
    FROM R04C0432 B
    INNER JOIN UNIVERSO U
        ON U.ID_CNBV = B.ID_CNBV
    WHERE B.PERIODO <= :PERIODO
)

SELECT

    U.ID_CNBV,

    UA.PERIODO    AS PERIODO_ULTIMA_ALTA,
    UA.TIPO_ALTA,

    UB.PERIODO    AS PERIODO_ULTIMA_BAJA,
    UB.TIPO_BAJA

FROM UNIVERSO U

LEFT JOIN ULTIMA_ALTA UA
       ON UA.ID_CNBV = U.ID_CNBV
      AND UA.RN = 1

LEFT JOIN ULTIMA_BAJA UB
       ON UB.ID_CNBV = U.ID_CNBV
      AND UB.RN = 1

ORDER BY
    U.ID_CNBV;

--cc_0005
WITH fideicomisos AS (

    SELECT DISTINCT
           RFC,
           PERIODO
    FROM R04C0430
    WHERE T_ALTA = 501
      AND TIPO_CAR IN (330,340)

),

historial AS (

    SELECT t.*
    FROM R04C0430 t
    JOIN fideicomisos f
      ON t.RFC = f.RFC

),

seguimientos AS (

    SELECT DISTINCT
           RFC,
           PERIODO
    FROM R04C0431

)

SELECT

    h.RFC,

    COUNT(*) AS TOTAL_REGISTROS,

    COUNT(DISTINCT h.NOMB_CLI)  AS NOMBRES,
    COUNT(DISTINCT h.MUNI_CRED) AS MUNICIPIOS,
    COUNT(DISTINCT h.LOC_CRED)  AS LOCALIDADES,
    COUNT(DISTINCT h.GPO_RIES)  AS GRUPOS_RIESGO,
    COUNT(DISTINCT h.ACT_ECO)   AS ACTIVIDADES,
    COUNT(DISTINCT h.TIPO_CAR)  AS TIPOS_CARTERA,

    CASE
        WHEN MAX(
            CASE
                WHEN s.RFC IS NOT NULL THEN 1
                ELSE 0
            END
        ) = 1
        THEN 'SI'
        ELSE 'NO'
    END AS TIENE_SEGUIMIENTO

FROM historial h

LEFT JOIN fideicomisos f
       ON f.RFC = h.RFC

LEFT JOIN seguimientos s
       ON s.RFC = f.RFC
      AND s.PERIODO = f.PERIODO

GROUP BY h.RFC

ORDER BY h.RFC;
