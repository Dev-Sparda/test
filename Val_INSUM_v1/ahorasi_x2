import json

class LoggerNormalizacion:

    def __init__(self):
        self.registro = {"errores": []}

    def _buscar_o_crear_parte(self, parte, rango):
        for entry in self.registro["errores"]:
            if entry["parte"] == parte and entry["rango"] == rango:
                return entry
        entry = {"parte": parte, "rango": rango, "errores": []}
        self.registro["errores"].append(entry)
        return entry

    def error_parte(self, parte, mensaje):
        entry = self._buscar_o_crear_parte(parte, None)
        entry["errores"].append({"error": mensaje})

    def error_parte_rango(self, parte, rango, mensaje):
        entry = self._buscar_o_crear_parte(parte, rango)
        entry["errores"].append({"error": mensaje})

    def error_columna(self, parte, rango, columna, mensaje):
        entry = self._buscar_o_crear_parte(parte, rango)
        entry["errores"].append({"columna": columna, "error": mensaje})

    def hay_errores(self):
        return len(self.registro["errores"]) > 0

    def to_json(self):
        return json.dumps(self.registro, ensure_ascii=False, indent=2)


