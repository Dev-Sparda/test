# logger_json.py

import json

class LoggerJSON:

    def __init__(self):
        self.errores = {
            "partes": {}
        }

    # ============================================================
    #   ERRORES A NIVEL PARTE
    # ============================================================

    def log_parte_error(self, parte, mensaje):
        """
        Cuando falló la lectura de una hoja / parte completa.
        """
        if parte not in self.errores["partes"]:
            self.errores["partes"][parte] = {}

        self.errores["partes"][parte]["_error_parte"] = mensaje

    # ============================================================
    #   ERRORES A NIVEL RANGO
    # ============================================================

    def log_rango_error(self, parte, rango, mensaje):
        """
        Cuando falló el recorte del rango (fila/col).
        """
        if parte not in self.errores["partes"]:
            self.errores["partes"][parte] = {}

        if rango not in self.errores["partes"][parte]:
            self.errores["partes"][parte][rango] = {}

        self.errores["partes"][parte][rango]["_error_rango"] = mensaje

    # ============================================================
    #   ERRORES A NIVEL COLUMNA
    # ============================================================

    def log_errores_columna(self, parte, rango, columna, errores_col):
        """
        Errores del validador de tipos (una o varias filas).
        """
        if parte not in self.errores["partes"]:
            self.errores["partes"][parte] = {}

        if rango not in self.errores["partes"][parte]:
            self.errores["partes"][parte][rango] = {}

        if "columnas" not in self.errores["partes"][parte][rango]:
            self.errores["partes"][parte][rango]["columnas"] = {}

        self.errores["partes"][parte][rango]["columnas"][columna] = errores_col

    # ============================================================
    #   OBTENER JSON
    # ============================================================

    def get_json(self):
        """
        Devuelve el dict con errores como JSON serializable.
        """
        return self.errores

    # ============================================================
    #   RESUMEN PLANO (para meter en MENSAJE_ERROR en la tabla)
    # ============================================================

    def resumen(self):
        """
        Devuelve el log como cadena JSON (usado en MENSAJE_ERROR).
        """
        try:
            return json.dumps(self.errores, ensure_ascii=False)
        except:
            return str(self.errores)


