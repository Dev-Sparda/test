import polars as pl


class FabricaCargadorArchivos:

    @staticmethod
    def cargar(ruta, tipo_archivo, hoja=None):

        if tipo_archivo == "CSV":
            return pl.scan_csv(
                ruta,
                has_header=False,
                infer_schema_length=0,
                low_memory=True
            )

        elif tipo_archivo == "TXT":
            return pl.scan_csv(
                ruta,
                separator="\t",
                has_header=False,
                infer_schema_length=0,
                low_memory=True
            )

        elif tipo_archivo == "EXCEL":
            return (
                pl.read_excel(
                    ruta,
                    sheet_name=hoja,
                    has_header=False
                )
                .lazy()
            )

        else:
            raise ValueError("Tipo de archivo no soportado")
