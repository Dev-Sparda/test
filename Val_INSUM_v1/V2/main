# main.py
import argparse
import sys
from datetime import datetime

# Registrar validadores
from fabrica_validadores import FabricaValidadores
from validador_sla import ValidadorSLA
from validador_cruce import ValidadorCruce


def registrar_validadores():
    """Registra todos los tipos de validadores"""
    print("\n" + "="*50)
    print("REGISTRO DE VALIDADORES")
    print("="*50)
    
    FabricaValidadores.registrar("SLA", ValidadorSLA)
    FabricaValidadores.registrar("CRUCE", ValidadorCruce)
    
    print(f"\n✅ Validadores disponibles: {FabricaValidadores.obtener_tipos_disponibles()}")
    print("="*50 + "\n")


def main():
    """Función principal"""
    # Configurar argumentos
    parser = argparse.ArgumentParser(
        description="Validador de Insumos - Procesa archivos según configuración en BD"
    )
    
    parser.add_argument(
        "--id_insumo", 
        type=int, 
        required=True,
        help="ID del insumo a procesar"
    )
    
    parser.add_argument(
        "--db_path", 
        type=str, 
        default="configuracion.db",
        help="Ruta a la base de datos (default: configuracion.db)"
    )
    
    parser.add_argument(
        "--no-streaming", 
        action="store_true",
        help="Deshabilitar modo streaming"
    )
    
    parser.add_argument(
        "--verbose", 
        action="store_true",
        help="Mostrar mensajes detallados"
    )
    
    args = parser.parse_args()
    
    # Registrar validadores
    registrar_validadores()
    
    # Crear orquestador
    from orquestador_insumo import OrquestadorInsumo
    
    orquestador = OrquestadorInsumo(
        id_insumo=args.id_insumo,
        ruta_db=args.db_path,
        modo_streaming=not args.no_streaming,
        verbose=args.verbose
    )
    
    # Ejecutar procesamiento
    try:
        print(f"\n🚀 Iniciando procesamiento de insumo {args.id_insumo}")
        print(f"📂 Base de datos: {args.db_path}")
        print(f"💾 Modo streaming: {not args.no_streaming}")
        print(f"📝 Modo verbose: {args.verbose}")
        print("-" * 50)
        
        resultados = orquestador.procesar()
        
        return 0
        
    except Exception as e:
        print(f"\n❌ ERROR: {str(e)}", file=sys.stderr)
        if args.verbose:
            import traceback
            traceback.print_exc()
        return 1


if __name__ == "__main__":
    sys.exit(main())
