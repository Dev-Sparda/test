# repositorio_configuracion.py
import duckdb
import polars as pl
from typing import List, Dict, Optional, Tuple


class RepositorioConfiguracion:
    """
    Clase que maneja el acceso a la base de datos de configuración
    Usa context manager (__enter__/__exit__) para manejar la conexión automáticamente
    """
    
    def __init__(self, ruta_db: str):
        """
        Constructor: guarda la ruta de la base de datos
        """
        self.ruta_db = ruta_db
        self.conn = None  # Conexión, inicialmente None
    
    def __enter__(self):
        """
        Se ejecuta al entrar al bloque 'with'
        Abre la conexión a la base de datos
        """
        self.conn = duckdb.connect(self.ruta_db)
        return self  # Retorna el mismo objeto para usarlo dentro del with
    
    def __exit__(self, exc_type, exc_value, traceback):
        """
        Se ejecuta al salir del bloque 'with'
        Cierra la conexión automáticamente
        """
        if self.conn:
            self.conn.close()
    
    # ================================
    # INSUMO - Datos básicos del archivo
    # ================================
    
    def obtener_insumo(self, id_insumo: int) -> Optional[Tuple]:
        """
        Obtiene los datos básicos del insumo
        Returns: (ID_INSUMO, RUTA_ARCHIVO, TIPO_ARCHIVO) o None si no existe
        """
        resultado = self.conn.execute("""
            SELECT ID_INSUMO, RUTA_ARCHIVO, TIPO_ARCHIVO
            FROM CAT_INSUMOS
            WHERE ID_INSUMO = ?
        """, (id_insumo,)).fetchone()
        
        return resultado
    
    # ================================
    # PARTES - Cada parte puede ser una hoja de Excel o una sección del archivo
    # ================================
    
    def obtener_partes(self, id_insumo: int) -> List[Tuple]:
        """
        Obtiene todas las partes ACTIVAS de un insumo
        Returns: Lista de (ID_PARTE, NUM_PARTE, NOMBRE_PARTE)
        """
        return self.conn.execute("""
            SELECT ID_PARTE, NUM_PARTE, NOMBRE_PARTE
            FROM INSUMOS_PARTES
            WHERE ID_INSUMO = ?
              AND ESTATUS = TRUE  -- Solo partes activas
            ORDER BY NUM_PARTE
        """, (id_insumo,)).fetchall()
    
    # ================================
    # RANGOS - Definición de columnas por rango
    # ================================
    
    def obtener_rangos(self, id_parte: int) -> List[Tuple]:
        """
        Obtiene todos los rangos ACTIVOS de una parte
        Returns: Lista de (ID_RANGO, NUM_RANGO, NOMBRE_RANGO, COL_INICIO, COL_FIN)
        """
        return self.conn.execute("""
            SELECT ID_RANGO, NUM_RANGO, NOMBRE_RANGO,
                   COL_INICIO, COL_FIN
            FROM INSUMOS_RANGOS
            WHERE ID_PARTE = ?
              AND ESTATUS = TRUE
            ORDER BY NUM_RANGO
        """, (id_parte,)).fetchall()
    
    # ================================
    # DEFINICIÓN DE COLUMNAS - Esquema de cada rango
    # ================================
    
    def obtener_definicion_columnas(self, id_rango: int) -> Dict[str, pl.DataType]:
        """
        Obtiene la definición de columnas para un rango específico
        Returns: Diccionario {nombre_columna: tipo_dato_polars}
        """
        columnas = self.conn.execute("""
            SELECT INDEX_COL, NOMBRE_COLUMN, TIPO_DATO_SYS
            FROM DEFINICION_INSUMOS
            WHERE ID_RANGO = ?
              AND ESTATUS = TRUE
            ORDER BY INDEX_COL
        """, (id_rango,)).fetchall()
        
        # Mapeo de tipos de texto a tipos de Polars
        mapeo = {
            "INT": pl.Int64,
            "STRING": pl.Utf8,
            "DATE": pl.Utf8,   # Se puede convertir luego si quieres formato fecha real
            "FLOAT": pl.Float64
        }
        
        # Construir diccionario de esquema
        esquema = {}
        for _, nombre, tipo in columnas:
            esquema[nombre] = mapeo.get(tipo, pl.Utf8)  # Por defecto Utf8 si no se reconoce
        
        return esquema
    
    # ================================
    # VALIDACIONES - AHORA CON TIPO_VAL
    # ================================
    
    def obtener_validaciones(self, id_insumo: int) -> List[Dict]:
        """
        Obtiene TODAS las validaciones activas de un insumo
        Returns: Lista de diccionarios con datos de validación
        """
        resultados = self.conn.execute("""
            SELECT ID_VAL,
                   TIPO_VAL,        -- NUEVO: 'SLA', 'CRUCE', 'CALIDAD', etc.
                   VALIDACION,       -- Query SQL o configuración
                   DESCRIPCION,
                   GRUPO,
                   SECCION,
                   BANDERA,
                   CONFIG_JSON       -- NUEVO: Para configuraciones complejas (JSON)
            FROM MOTOR_VAL
            WHERE ID_INSUMO = ?
              AND ESTATUS = TRUE
        """, (id_insumo,)).fetchall()
        
        # Convertir a lista de diccionarios para más claridad
        validaciones = []
        for row in resultados:
            validaciones.append({
                "id_val": row[0],
                "tipo_val": row[1],
                "validacion": row[2],
                "descripcion": row[3],
                "grupo": row[4],
                "seccion": row[5],
                "bandera": row[6],
                "config_json": row[7]
            })
        
        return validaciones
    
    def obtener_validaciones_por_tipo(self, id_insumo: int) -> Dict[str, List[Dict]]:
        """
        Obtiene validaciones agrupadas por tipo
        Returns: Diccionario { 'SLA': [...], 'CRUCE': [...], ... }
        """
        todas = self.obtener_validaciones(id_insumo)
        
        # Agrupar por tipo
        por_tipo = {}
        for val in todas:
            tipo = val["tipo_val"]
            if tipo not in por_tipo:
                por_tipo[tipo] = []
            por_tipo[tipo].append(val)
        
        return por_tipo
