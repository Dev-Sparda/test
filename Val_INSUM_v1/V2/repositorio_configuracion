# repositorio_configuracion.py
import duckdb
import polars as pl
from pathlib import Path
from typing import List, Dict, Optional, Tuple
from datetime import datetime

# Importar constantes
from config import (
    DB_CAT_INSUMOS, DB_INSUMOS_PARTES, DB_INSUMOS_RANGOS,
    DB_DEFINICION_INSUMOS, DB_MOTOR_VAL, REPOSITORIO_INSUMOS
)


class RepositorioConfiguracion:
    """
    Clase que maneja el acceso a la base de datos de configuración
    AHORA con capacidad de construir rutas dinámicas con fechas
    """
    
    def __init__(self, ruta_db: str, fecha_proceso: datetime = None):
        """
        Args:
            ruta_db: Ruta al archivo de base de datos
            fecha_proceso: Fecha de proceso (para rutas con variables)
        """
        self.ruta_db = ruta_db
        self.fecha_proceso = fecha_proceso or datetime.now()
        self.conn = None
    
    def __enter__(self):
        self.conn = duckdb.connect(self.ruta_db)
        return self
    
    def __exit__(self, exc_type, exc_value, traceback):
        if self.conn:
            self.conn.close()
    
    # ============================================
    # MÉTODOS PARA MANEJAR RUTAS CON FECHAS
    # ============================================
    
    def _reemplazar_variables_fecha(self, ruta_base: str) -> str:
        """
        Reemplaza variables de fecha en una ruta
        Ejemplo: "Mock Insumo/mock 1/%Y/%Y%m" -> "Mock Insumo/mock 1/2024/202401"
        """
        # Reemplazar %Y con año
        ruta = ruta_base.replace("%Y", self.fecha_proceso.strftime("%Y"))
        
        # Reemplazar %m con mes
        ruta = ruta.replace("%m", self.fecha_proceso.strftime("%m"))
        
        # Reemplazar %Y%m con añomes
        ruta = ruta.replace("%Y%m", self.fecha_proceso.strftime("%Y%m"))
        
        # Reemplazar %d con día
        ruta = ruta.replace("%d", self.fecha_proceso.strftime("%d"))
        
        return ruta
    
    def _buscar_archivo_en_carpeta(self, carpeta: Path, patron: str = "*") -> Path:
        """
        Busca un archivo en una carpeta (para cuando no sabemos el nombre exacto)
        """
        if not carpeta.exists():
            raise FileNotFoundError(f"Carpeta no encontrada: {carpeta}")
        
        # Buscar archivos que coincidan con el patrón
        archivos = list(carpeta.glob(patron))
        
        if not archivos:
            raise FileNotFoundError(f"No se encontraron archivos en {carpeta}")
        
        # Si hay múltiples, tomar el más reciente o el primero
        # Aquí puedes implementar lógica más compleja
        return archivos[0]
    
    def obtener_ruta_archivo_insumo(self, id_insumo: int) -> Tuple[str, str, Path]:
        """
        Obtiene la ruta COMPLETA y real de un insumo
        Returns: (tipo_archivo, nombre_original, ruta_completa)
        """
        # 1. Obtener registro del insumo
        resultado = self.conn.execute(f"""
            SELECT RUTA_ARCHIVO, TIPO_ARCHIVO, PATRON_BUSQUEDA
            FROM {DB_CAT_INSUMOS}
            WHERE ID_INSUMO = ?
        """, (id_insumo,)).fetchone()
        
        if not resultado:
            raise ValueError(f"Insumo {id_insumo} no encontrado")
        
        ruta_relativa, tipo_archivo, patron = resultado
        
        # 2. Reemplazar variables de fecha en la ruta
        ruta_con_fecha = self._reemplazar_variables_fecha(ruta_relativa)
        
        # 3. Construir ruta completa dentro del repositorio
        ruta_completa = REPOSITORIO_INSUMOS / ruta_con_fecha
        
        # 4. Si es una carpeta, buscar archivo dentro
        if ruta_completa.is_dir():
            if patron:
                ruta_completa = self._buscar_archivo_en_carpeta(ruta_completa, patron)
            else:
                # Buscar por extensión según tipo
                if tipo_archivo == "CSV":
                    ruta_completa = self._buscar_archivo_en_carpeta(ruta_completa, "*.csv")
                elif tipo_archivo == "EXCEL":
                    ruta_completa = self._buscar_archivo_en_carpeta(ruta_completa, "*.xlsx")
                elif tipo_archivo == "TXT":
                    ruta_completa = self._buscar_archivo_en_carpeta(ruta_completa, "*.txt")
        
        return tipo_archivo, ruta_relativa, ruta_completa
    
    # ============================================
    # MÉTODOS ORIGINALES ACTUALIZADOS
    # ============================================
    
    def obtener_insumo(self, id_insumo: int) -> Optional[Tuple]:
        """
        Obtiene los datos básicos del insumo con ruta REAL
        Returns: (ID_INSUMO, RUTA_COMPLETA, TIPO_ARCHIVO)
        """
        try:
            tipo_archivo, ruta_original, ruta_completa = self.obtener_ruta_archivo_insumo(id_insumo)
            
            # También podemos devolver metadatos adicionales
            return (
                id_insumo,
                str(ruta_completa),  # Ruta absoluta real
                tipo_archivo,
                str(ruta_original)    # Ruta original con variables (para referencia)
            )
        except Exception as e:
            print(f"Error obteniendo insumo {id_insumo}: {e}")
            return None
    
    def obtener_partes(self, id_insumo: int) -> List[Tuple]:
        """Sin cambios - igual que antes"""
        return self.conn.execute(f"""
            SELECT ID_PARTE, NUM_PARTE, NOMBRE_PARTE
            FROM {DB_INSUMOS_PARTES}
            WHERE ID_INSUMO = ?
              AND ESTATUS = TRUE
            ORDER BY NUM_PARTE
        """, (id_insumo,)).fetchall()
    
    def obtener_rangos(self, id_parte: int) -> List[Tuple]:
        """Sin cambios"""
        return self.conn.execute(f"""
            SELECT ID_RANGO, NUM_RANGO, NOMBRE_RANGO,
                   COL_INICIO, COL_FIN
            FROM {DB_INSUMOS_RANGOS}
            WHERE ID_PARTE = ?
              AND ESTATUS = TRUE
            ORDER BY NUM_RANGO
        """, (id_parte,)).fetchall()
    
    def obtener_definicion_columnas(self, id_rango: int) -> Dict[str, pl.DataType]:
        """Sin cambios"""
        columnas = self.conn.execute(f"""
            SELECT INDEX_COL, NOMBRE_COLUMN, TIPO_DATO_SYS
            FROM {DB_DEFINICION_INSUMOS}
            WHERE ID_RANGO = ?
              AND ESTATUS = TRUE
            ORDER BY INDEX_COL
        """, (id_rango,)).fetchall()
        
        mapeo = {
            "INT": pl.Int64,
            "STRING": pl.Utf8,
            "DATE": pl.Utf8,
            "FLOAT": pl.Float64
        }
        
        esquema = {}
        for _, nombre, tipo in columnas:
            esquema[nombre] = mapeo.get(tipo, pl.Utf8)
        
        return esquema
    
    def obtener_validaciones(self, id_insumo: int) -> List[Dict]:
        """Sin cambios"""
        resultados = self.conn.execute(f"""
            SELECT ID_VAL,
                   TIPO_VAL,
                   VALIDACION,
                   DESCRIPCION,
                   GRUPO,
                   SECCION,
                   BANDERA,
                   CONFIG_JSON
            FROM {DB_MOTOR_VAL}
            WHERE ID_INSUMO = ?
              AND ESTATUS = TRUE
        """, (id_insumo,)).fetchall()
        
        validaciones = []
        for row in resultados:
            validaciones.append({
                "id_val": row[0],
                "tipo_val": row[1],
                "validacion": row[2],
                "descripcion": row[3],
                "grupo": row[4],
                "seccion": row[5],
                "bandera": row[6],
                "config_json": row[7]
            })
        
        return validaciones
    
    def obtener_validaciones_por_tipo(self, id_insumo: int) -> Dict[str, List[Dict]]:
        """Sin cambios"""
        todas = self.obtener_validaciones(id_insumo)
        
        por_tipo = {}
        for val in todas:
            tipo = val["tipo_val"]
            if tipo not in por_tipo:
                por_tipo[tipo] = []
            por_tipo[tipo].append(val)
        
        return por_tipo
