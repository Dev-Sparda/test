ALTER TABLE MOTOR_VAL ADD COLUMN TIPO_VAL VARCHAR(20) DEFAULT 'SLA';
ALTER TABLE MOTOR_VAL ADD COLUMN CONFIG_JSON TEXT;

-- Comentarios
COMMENT ON COLUMN MOTOR_VAL.TIPO_VAL IS 'Tipo de validación: SLA, CRUCE, CALIDAD, HISTORICO, etc.';
COMMENT ON COLUMN MOTOR_VAL.CONFIG_JSON IS 'Configuración adicional en JSON para validaciones complejas';

