# test_csv_corregido.py
import duckdb

print("🔍 Diagnóstico de CSV")
print("="*50)

conn = duckdb.connect()

# 1. Ver las primeras líneas del archivo como texto
with open('cat_insumos.csv', 'r', encoding='utf-8') as f:
    primeras_lineas = [next(f) for _ in range(3)]
    print("\n📄 Primeras 3 líneas del archivo:")
    for i, linea in enumerate(primeras_lineas):
        print(f"   Línea {i+1}: {linea.rstrip()}")

# 2. Probar diferentes separadores
separadores = [',', ';', '\t', '|']
print("\n🔍 Probando separadores:")

for sep in separadores:
    try:
        resultado = conn.execute(f"""
            SELECT * FROM read_csv_auto(
                'cat_insumos.csv',
                sep='{sep}',
                header=True,
                sample_size=1000
            )
        """).fetchdf()
        
        print(f"\n✅ Separador '{sep}':")
        print(f"   Columnas: {resultado.columns.tolist()}")
        print(f"   Shape: {resultado.shape}")
        if len(resultado.columns) > 1:
            print("   ¡ESTE PARECE SER EL CORRECTO!")
            print("\nPrimeros registros:")
            print(resultado.head(3))
    except Exception as e:
        print(f"❌ Separador '{sep}': Error - {e}")

conn.close()
