# main.py
import argparse
import sys

from fabrica_validadores import FabricaValidadores
from validador_sla import ValidadorSLA
from validador_cruce import ValidadorCruce


def registrar_validadores():
    """Registra todos los tipos de validadores"""
    print("\n" + "="*50)
    print("REGISTRO DE VALIDADORES")
    print("="*50)
    FabricaValidadores.registrar("SLA", ValidadorSLA)
    FabricaValidadores.registrar("CRUCE", ValidadorCruce)
    print(f"\n✅ Validadores disponibles: {FabricaValidadores.obtener_tipos_disponibles()}")


def main():
    parser = argparse.ArgumentParser(description="Validador de Insumos")
    parser.add_argument("--id_insumo", type=int, required=True, help="ID del insumo")
    parser.add_argument("--db_path", type=str, default="configuracion.db", help="Ruta a BD")
    parser.add_argument("--no-streaming", action="store_true", help="Deshabilitar streaming")
    parser.add_argument("--verbose", action="store_true", help="Mostrar detalles")
    
    args = parser.parse_args()
    
    registrar_validadores()
    
    from orquestador_insumo import OrquestadorInsumo
    
    orquestador = OrquestadorInsumo(
        id_insumo=args.id_insumo,
        ruta_db=args.db_path,
        modo_streaming=not args.no_streaming,
        verbose=args.verbose
    )
    
    try:
        print(f"\n🚀 Procesando insumo {args.id_insumo}")
        print(f"📂 BD: {args.db_path}")
        print("-" * 50)
        
        orquestador.procesar()
        return 0
        
    except Exception as e:
        print(f"\n❌ ERROR: {str(e)}")
        if args.verbose:
            import traceback
            traceback.print_exc()
        return 1


if __name__ == "__main__":
    sys.exit(main())
