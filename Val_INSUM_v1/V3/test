# test_repositorio.py
from repositorio_configuracion import RepositorioConfiguracion
from config import DB_CONFIG

def test_repositorio():
    print("="*50)
    print("PRUEBA DE REPOSITORIO")
    print("="*50)
    
    try:
        with RepositorioConfiguracion(DB_CONFIG) as repo:
            print("\n🔍 Probando obtener_insumo(1)...")
            insumo = repo.obtener_insumo(1)
            print(f"✅ Resultado: {insumo}")
            
    except Exception as e:
        print(f"\n❌ Error: {type(e).__name__}: {e}")
        import traceback
        traceback.print_exc()

if __name__ == "__main__":
    test_repositorio()





# test_duckdb_directo.py
import duckdb
from config import CSV_CAT_INSUMOS

print("="*50)
print("PRUEBA DIRECTA CON DUCKDB")
print("="*50)

# Conectar a una base en memoria
conn = duckdb.connect()

# Leer el CSV directamente
print(f"\n📄 Leyendo {CSV_CAT_INSUMOS}...")
df = conn.execute(f"SELECT * FROM read_csv_auto('{CSV_CAT_INSUMOS}')").fetchdf()
print(f"✅ Columnas: {df.columns.tolist()}")
print(f"✅ Registros: {len(df)}")
print("\nPrimeros 3 registros:")
print(df.head(3))

# Probar consulta con WHERE
print("\n🔍 Probando WHERE ID_INSUMO = 1...")
resultado = conn.execute("""
    SELECT ID_INSUMO, RUTA_ARCHIVO, TIPO_ARCHIVO 
    FROM read_csv_auto('{}') 
    WHERE ID_INSUMO = 1
""".format(CSV_CAT_INSUMOS)).fetchone()
print(f"✅ Resultado: {resultado}")

conn.close()
