import duckdb
import polars as pl
from pathlib import Path
from typing import List, Dict, Optional, Tuple

from config import (
    CSV_CAT_INSUMOS,
    DB_INSUMOS_PARTES, 
    DB_INSUMOS_RANGOS,
    DB_DEFINICION_INSUMOS, 
    DB_MOTOR_VAL, 
    REPOSITORIO_INSUMOS
)


class RepositorioConfiguracion:
    
    def __init__(self, ruta_db: str):
        self.ruta_db = ruta_db
        self.conn = None
    
    def __enter__(self):
        print(f"🔌 Conectando a DB: {self.ruta_db}")
        self.conn = duckdb.connect(self.ruta_db)
        
        # Registrar CSV
        if CSV_CAT_INSUMOS.exists():
            print(f"📄 Leyendo CSV: {CSV_CAT_INSUMOS}")
            
            # Verificar que el CSV se puede leer
            try:
                # Probar lectura directa
                test = self.conn.execute(f"""
                    SELECT * FROM read_csv_auto('{CSV_CAT_INSUMOS}') LIMIT 1
                """).fetchall()
                print(f"✅ CSV se lee correctamente. Columnas disponibles en consulta directa")
                
                # Crear vista
                self.conn.execute(f"""
                    CREATE OR REPLACE VIEW CAT_INSUMOS AS 
                    SELECT * FROM read_csv_auto('{CSV_CAT_INSUMOS}')
                """)
                print(f"✅ Vista CAT_INSUMOS creada")
                
                # Verificar que la vista funciona
                test_vista = self.conn.execute("SELECT * FROM CAT_INSUMOS LIMIT 1").fetchall()
                print(f"✅ Vista funciona correctamente")
                
                # Mostrar estructura de la vista
                columnas = self.conn.execute("DESCRIBE CAT_INSUMOS").fetchall()
                print(f"📋 Columnas en vista: {[c[0] for c in columnas]}")
                
            except Exception as e:
                print(f"❌ Error al procesar CSV: {e}")
                raise
        else:
            raise FileNotFoundError(f"Archivo CAT_INSUMOS no encontrado: {CSV_CAT_INSUMOS}")
        
        return self
    
    def __exit__(self, exc_type, exc_value, traceback):
        if self.conn:
            self.conn.close()
            print("🔌 Conexión cerrada")
    
    def obtener_insumo(self, id_insumo: int) -> Optional[Tuple]:
        """Obtiene los datos del insumo desde la vista CAT_INSUMOS"""
        print(f"🔍 Buscando insumo ID: {id_insumo}")
        
        # Primero, verificar qué datos hay en la vista
        todos = self.conn.execute("SELECT * FROM CAT_INSUMOS").fetchall()
        print(f"📊 Total registros en CAT_INSUMOS: {len(todos)}")
        if len(todos) > 0:
            print(f"   Primer registro: {todos[0]}")
        
        # Intentar la consulta específica
        try:
            resultado = self.conn.execute("""
                SELECT ID_INSUMO, RUTA_ARCHIVO, TIPO_ARCHIVO
                FROM CAT_INSUMOS
                WHERE ID_INSUMO = ?
            """, (id_insumo,)).fetchone()
            
            print(f"   Resultado búsqueda: {resultado}")
            
        except Exception as e:
            print(f"❌ Error en consulta: {e}")
            
            # Intentar sin el WHERE para ver si es problema de la columna
            try:
                test = self.conn.execute("SELECT ID_INSUMO FROM CAT_INSUMOS LIMIT 1").fetchone()
                print(f"   Test columna ID_INSUMO: {test}")
            except Exception as e2:
                print(f"   ❌ Error al acceder a ID_INSUMO: {e2}")
            
            raise
        
        if not resultado:
            return None
        
        id_insumo, ruta_relativa, tipo_archivo = resultado
        ruta_completa = REPOSITORIO_INSUMOS / ruta_relativa
        
        return (id_insumo, str(ruta_completa), tipo_archivo)
    
