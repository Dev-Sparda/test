# repositorio_configuracion.py
import duckdb
import polars as pl
from pathlib import Path
from typing import List, Dict, Optional, Tuple

from config import (
    CSV_CAT_INSUMOS,
    DB_INSUMOS_PARTES, 
    DB_INSUMOS_RANGOS,
    DB_DEFINICION_INSUMOS, 
    DB_MOTOR_VAL, 
    REPOSITORIO_INSUMOS
)


class RepositorioConfiguracion:
    """
    TODO con DuckDB:
    - CSV registrado como tabla virtual
    - Tablas de BD normales
    """
    
    def __init__(self, ruta_db: str):
        self.ruta_db = ruta_db
        self.conn = None
    
    def __enter__(self):
        """Conecta a DuckDB y registra el CSV"""
        self.conn = duckdb.connect(self.ruta_db)
        
        # Registrar CSV si existe
        if CSV_CAT_INSUMOS.exists():
            self.conn.execute(f"""
                CREATE OR REPLACE VIEW CAT_INSUMOS AS 
                SELECT * FROM read_csv_auto('{CSV_CAT_INSUMOS}')
            """)
            print(f"✅ Vista CAT_INSUMOS creada desde: {CSV_CAT_INSUMOS}")
        else:
            raise FileNotFoundError(f"Archivo CAT_INSUMOS no encontrado: {CSV_CAT_INSUMOS}")
        
        return self
    
    def __exit__(self, exc_type, exc_value, traceback):
        if self.conn:
            self.conn.close()
    
    # ============================================
    # MÉTODOS PARA CAT_INSUMOS (DESDE VISTA DEL CSV)
    # ============================================
    
    def obtener_insumo(self, id_insumo: int) -> Optional[Tuple]:
        """
        Obtiene los datos del insumo desde la vista CAT_INSUMOS
        Returns: (ID_INSUMO, RUTA_COMPLETA, TIPO_ARCHIVO)
        """
        resultado = self.conn.execute("""
            SELECT ID_INSUMO, RUTA_ARCHIVO, TIPO_ARCHIVO
            FROM CAT_INSUMOS
            WHERE ID_INSUMO = ?
        """, (id_insumo,)).fetchone()
        
        if not resultado:
            return None
        
        id_insumo, ruta_relativa, tipo_archivo = resultado
        
        # Construir ruta completa dentro del repositorio
        ruta_completa = REPOSITORIO_INSUMOS / ruta_relativa
        
        return (id_insumo, str(ruta_completa), tipo_archivo)
    
    def obtener_todos_insumos(self) -> List[Dict]:
        """Obtiene todos los insumos del catálogo"""
        resultados = self.conn.execute("""
            SELECT ID_INSUMO, RUTA_ARCHIVO, TIPO_ARCHIVO
            FROM CAT_INSUMOS
            ORDER BY ID_INSUMO
        """).fetchall()
        
        return [
            {"id_insumo": r[0], "ruta_archivo": r[1], "tipo_archivo": r[2]}
            for r in resultados
        ]
    
    # ============================================
    # MÉTODOS PARA CONFIGURACIÓN DE VALIDACIONES (TABLAS DUCKDB)
    # ============================================
    
    def obtener_partes(self, id_insumo: int) -> List[Tuple]:
        """Obtiene todas las partes activas desde DuckDB"""
        return self.conn.execute(f"""
            SELECT ID_PARTE, NUM_PARTE, NOMBRE_PARTE
            FROM {DB_INSUMOS_PARTES}
            WHERE ID_INSUMO = ?
              AND ESTATUS = TRUE
            ORDER BY NUM_PARTE
        """, (id_insumo,)).fetchall()
    
    def obtener_rangos(self, id_parte: int) -> List[Tuple]:
        """Obtiene todos los rangos activos de una parte"""
        return self.conn.execute(f"""
            SELECT ID_RANGO, NUM_RANGO, NOMBRE_RANGO,
                   COL_INICIO, COL_FIN
            FROM {DB_INSUMOS_RANGOS}
            WHERE ID_PARTE = ?
              AND ESTATUS = TRUE
            ORDER BY NUM_RANGO
        """, (id_parte,)).fetchall()
    
    def obtener_definicion_columnas(self, id_rango: int) -> Dict[str, pl.DataType]:
        """Obtiene la definición de columnas para un rango"""
        columnas = self.conn.execute(f"""
            SELECT INDEX_COL, NOMBRE_COLUMN, TIPO_DATO_SYS
            FROM {DB_DEFINICION_INSUMOS}
            WHERE ID_RANGO = ?
              AND ESTATUS = TRUE
            ORDER BY INDEX_COL
        """, (id_rango,)).fetchall()
        
        mapeo = {
            "INT": pl.Int64,
            "STRING": pl.Utf8,
            "DATE": pl.Utf8,
            "FLOAT": pl.Float64
        }
        
        esquema = {}
        for _, nombre, tipo in columnas:
            esquema[nombre] = mapeo.get(tipo, pl.Utf8)
        
        return esquema
    
    def obtener_validaciones(self, id_insumo: int) -> List[Dict]:
        """Obtiene todas las validaciones activas desde DuckDB"""
        resultados = self.conn.execute(f"""
            SELECT ID_VAL,
                   TIPO_VAL,
                   VALIDACION,
                   DESCRIPCION,
                   GRUPO,
                   SECCION,
                   BANDERA,
                   CONFIG_JSON
            FROM {DB_MOTOR_VAL}
            WHERE ID_INSUMO = ?
              AND ESTATUS = TRUE
        """, (id_insumo,)).fetchall()
        
        validaciones = []
        for row in resultados:
            validaciones.append({
                "id_val": row[0],
                "tipo_val": row[1],
                "validacion": row[2],
                "descripcion": row[3],
                "grupo": row[4],
                "seccion": row[5],
                "bandera": row[6],
                "config_json": row[7]
            })
        
        return validaciones
    
    def obtener_validaciones_por_tipo(self, id_insumo: int) -> Dict[str, List[Dict]]:
        """Obtiene validaciones agrupadas por tipo"""
        todas = self.obtener_validaciones(id_insumo)
        
        por_tipo = {}
        for val in todas:
            tipo = val["tipo_val"]
            if tipo not in por_tipo:
                por_tipo[tipo] = []
            por_tipo[tipo].append(val)
        
        return por_tipo
