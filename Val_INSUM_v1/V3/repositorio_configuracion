# repositorio_configuracion_simple.py
import duckdb
import polars as pl
from pathlib import Path
from typing import List, Dict, Optional, Tuple

from config import (
    CSV_CAT_INSUMOS,
    DB_INSUMOS_PARTES, 
    DB_INSUMOS_RANGOS,
    DB_DEFINICION_INSUMOS, 
    DB_MOTOR_VAL, 
    REPOSITORIO_INSUMOS
)


class RepositorioConfiguracion:
    """Versión simplificada - usa tu método de consulta directa"""
    
    def __init__(self, ruta_db: str):
        self.ruta_db = ruta_db
        self.conn = None
    
    def __enter__(self):
        # Conectar a DuckDB
        self.conn = duckdb.connect(self.ruta_db)
        
        # No crear vista, solo guardar la ruta del CSV
        self.csv_path = str(CSV_CAT_INSUMOS)
        print(f"📁 CSV disponible: {self.csv_path}")
        
        return self
    
    def __exit__(self, exc_type, exc_value, traceback):
        if self.conn:
            self.conn.close()
    
    def obtener_insumo(self, id_insumo: int) -> Optional[Tuple]:
        """Usando TU método - consulta directa al CSV"""
        try:
            # Tal cual como lo hiciste tú
            resultado = self.conn.execute(f"""
                SELECT ID_INSUMO, RUTA_ARCHIVO, TIPO_ARCHIVO 
                FROM '{self.csv_path}' 
                WHERE ID_INSUMO = {id_insumo}
            """).fetchone()
            
            if not resultado:
                return None
            
            id_insumo, ruta_relativa, tipo_archivo = resultado
            ruta_completa = REPOSITORIO_INSUMOS / ruta_relativa
            
            return (id_insumo, str(ruta_completa), tipo_archivo)
            
        except Exception as e:
            print(f"Error consultando insumo {id_insumo}: {e}")
            return None
    
    def obtener_todos_insumos(self) -> List[Dict]:
        """Obtener todos los insumos del CSV"""
        try:
            resultados = self.conn.execute(f"""
                SELECT ID_INSUMO, RUTA_ARCHIVO, TIPO_ARCHIVO 
                FROM '{self.csv_path}'
                ORDER BY ID_INSUMO
            """).fetchall()
            
            return [
                {"id_insumo": r[0], "ruta_archivo": r[1], "tipo_archivo": r[2]}
                for r in resultados
            ]
        except Exception as e:
            print(f"Error obteniendo todos los insumos: {e}")
            return []
    
    # ============================================
    # MÉTODOS PARA CONFIGURACIÓN DE VALIDACIONES (TABLAS DUCKDB)
    # ============================================
    
    def obtener_insumos_a_procesar(self) -> List[int]:
        """Obtiene IDs de insumos DISTINCT desde INSUMOS_PARTES"""
        resultados = self.conn.execute(f"""
            SELECT DISTINCT ID_INSUMO 
            FROM {DB_INSUMOS_PARTES}
            WHERE ESTATUS = TRUE
            ORDER BY ID_INSUMO
        """).fetchall()
        
        return [r[0] for r in resultados]
    
    def obtener_partes(self, id_insumo: int) -> List[Tuple]:
        """Obtiene todas las partes activas desde DuckDB"""
        return self.conn.execute(f"""
            SELECT ID_PARTE, NUM_PARTE, NOMBRE_PARTE
            FROM {DB_INSUMOS_PARTES}
            WHERE ID_INSUMO = ?
              AND ESTATUS = TRUE
            ORDER BY NUM_PARTE
        """, (id_insumo,)).fetchall()
    
    def obtener_rangos(self, id_parte: int) -> List[Tuple]:
        """Obtiene todos los rangos activos de una parte"""
        return self.conn.execute(f"""
            SELECT ID_RANGO, NUM_RANGO, NOMBRE_RANGO,
                   COL_INICIO, COL_FIN
            FROM {DB_INSUMOS_RANGOS}
            WHERE ID_PARTE = ?
              AND ESTATUS = TRUE
            ORDER BY NUM_RANGO
        """, (id_parte,)).fetchall()
    
    def obtener_definicion_columnas(self, id_rango: int) -> Dict[str, pl.DataType]:
        """Obtiene la definición de columnas para un rango"""
        columnas = self.conn.execute(f"""
            SELECT INDEX_COL, NOMBRE_COLUMN, TIPO_DATO_SYS
            FROM {DB_DEFINICION_INSUMOS}
            WHERE ID_RANGO = ?
              AND ESTATUS = TRUE
            ORDER BY INDEX_COL
        """, (id_rango,)).fetchall()
        
        mapeo = {
            "INT": pl.Int64,
            "STRING": pl.Utf8,
            "DATE": pl.Utf8,
            "FLOAT": pl.Float64
        }
        
        esquema = {}
        for _, nombre, tipo in columnas:
            esquema[nombre] = mapeo.get(tipo, pl.Utf8)
        
        return esquema
    
    def obtener_validaciones(self, id_insumo: int) -> List[Dict]:
        """Obtiene todas las validaciones activas desde DuckDB"""
        resultados = self.conn.execute(f"""
            SELECT ID_VAL,
                   TIPO_VAL,
                   VALIDACION,
                   DESCRIPCION,
                   GRUPO,
                   SECCION,
                   BANDERA,
                   CONFIG_JSON
            FROM {DB_MOTOR_VAL}
            WHERE ID_INSUMO = ?
              AND ESTATUS = TRUE
        """, (id_insumo,)).fetchall()
        
        validaciones = []
        for row in resultados:
            validaciones.append({
                "id_val": row[0],
                "tipo_val": row[1],
                "validacion": row[2],
                "descripcion": row[3],
                "grupo": row[4],
                "seccion": row[5],
                "bandera": row[6],
                "config_json": row[7]
            })
        
        return validaciones
    
    def obtener_validaciones_por_tipo(self, id_insumo: int) -> Dict[str, List[Dict]]:
        """Obtiene validaciones agrupadas por tipo"""
        todas = self.obtener_validaciones(id_insumo)
        
        por_tipo = {}
        for val in todas:
            tipo = val["tipo_val"]
            if tipo not in por_tipo:
                por_tipo[tipo] = []
            por_tipo[tipo].append(val)
        
        return por_tipo
