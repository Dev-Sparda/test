import pandas as pd
from pathlib import Path

class RepoCrearBase:
    """
    Repositorio encargado de:
    - Crear todas las tablas de la base según df_config
    - Cargar DataFrames a las tablas
    """

    def __init__(self, ruta_db: Path, df_config: pd.DataFrame, db_manager_cls):
        """
        :param ruta_db: Path hacia la base SQLite
        :param df_config: DataFrame de configuración del insumo
        :param db_manager_cls: clase DBManager (ya implementada)
        """
        self.ruta_db = ruta_db
        self.df_config = df_config
        self.db_manager_cls = db_manager_cls

    # ----------------------------------------------------------
    # 1. CREAR TABLAS SEGÚN CONFIGURACIÓN
    # ----------------------------------------------------------
    def crear_tablas(self):
        """
        Crea todas las tablas (una por cada NOMBRE_RANGO).
        Cada tabla usa columnas, tipos y PK según df_config.
        """
        # Agrupar por cada rango (cada rango es una tabla)
        for nombre_rango, df_rango in self.df_config.groupby("NOMBRE_RANGO"):
            columnas_sql = []

            for _, row in df_rango.iterrows():
                col_name = row["NOMBRE_COLUMN"]
                col_type = row["TIPO_DATO_SYS"]   # TEXT, REAL, DATE, etc.
                is_pk = row["KEY_COLUMN"] == 1

                if is_pk:
                    columnas_sql.append(f"{col_name} {col_type} PRIMARY KEY")
                else:
                    columnas_sql.append(f"{col_name} {col_type}")

            columnas_join = ", ".join(columnas_sql)
            query = f"CREATE TABLE IF NOT EXISTS {nombre_rango} ({columnas_join});"

            # Ejecutar query usando DBManager
            with self.db_manager_cls(self.ruta_db) as db:
                db.ejecutar_dml(query)

    # ----------------------------------------------------------
    # 2. CARGA DE DATAFRAME A TABLA
    # ----------------------------------------------------------
    def cargar_df(self, df: pd.DataFrame, nombre_tabla: str):
        """
        Inserta un DataFrame a una tabla ya creada.
        """
        with self.db_manager_cls(self.ruta_db) as db:
            db.cargar_df_tabla(df, nombre_tabla)



