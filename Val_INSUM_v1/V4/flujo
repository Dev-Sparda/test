class OrquestadorValidaciones:
    def __init__(self, ruta_db):
        self.repo = RepositorioConfiguracion(ruta_db)
    def ejecutar(self):
        insumos = self.repo.obtener_insumos_con_validacion()
        for insumo in insumos.iter_rows(named=True):
            id_insumo = insumo["ID_INSUMO"]
            tipo_val = insumo["TIPO_VAL"]
            fecha_inicio = insumo["FECHA_INICIO"]
            print(f"Procesando insumo {id_insumo}")
            config = self.repo.obtener_configuracion_insumo(id_insumo)
            reglas = self.repo.obtener_validaciones(id_insumo)
            # reglas ya vienen ordenadas por PRIORIDAD
            for regla in reglas:
                validador = FabricaValidadores.crear_validador(
                    regla["TIPO_VAL"],
                    config,
                    regla
                )
                resultado = validador.ejecutar(fecha_inicio)
                if not resultado.continuar:
                    break


6. Validador SLA (flujo principal)
Aquí se decide:
validar SLA
generar CSV
continuar o detener pipeline
class ValidadorSLA:
    def __init__(self, config, regla):
        self.config = config
        self.regla = regla
        self.generador_csv = GeneradorCSV()
    def ejecutar(self, fecha_inicio):
        df = self.cargar_archivo()
        sla_ok = self.validar_sla(df)
        if sla_ok:
            self.generador_csv.generar(
                df,
                self.config["ruta_salida"],
                self.config["ID_INSUMO"],
                fecha_inicio
            )
            return ResultadoValidacion(True, True)
        # revisar si el insumo es remediable
        if self.es_remediable():
            self.generador_csv.generar(
                df,
                self.config["ruta_salida"],
                self.config["ID_INSUMO"],
                fecha_inicio
            )
            return ResultadoValidacion(False, True)
        return ResultadoValidacion(False, False)




