class NormalizadorInsumo:
    """
    Responsable de:
    - Leer archivo según tipo
    - Particionarlo en partes y rangos
    - Validar tipado
    - Insertar en BD
    - Generar logs de errores
    """

    def __init__(
        self,
        ruta_db,
        df_config,
        ruta_archivo,
        tipo_archivo,
        version_origen,
        version_normalizada,
        lista_insumos_remediacion,
        db_manager_cls
    ):
        self.ruta_db = ruta_db
        self.df_config = df_config
        self.ruta_archivo = ruta_archivo
        self.tipo_archivo = tipo_archivo
        self.version_origen = version_origen
        self.version_normalizada = version_normalizada
        self.remediacion = lista_insumos_remediacion
        self.DB = db_manager_cls

    # ---------------------------
    # LECTURA DE ARCHIVOS
    # ---------------------------
    def leer_archivo(self):
        if self.tipo_archivo == "xlsx":
            return pd.read_excel(self.ruta_archivo, header=None, sheet_name=None)
        if self.tipo_archivo == "csv":
            return pd.read_csv(self.ruta_archivo, header=None)
        if self.tipo_archivo == "txt":
            return pd.read_csv(self.ruta_archivo, header=None, sep="|")
        if self.tipo_archivo == "html":
            return pd.read_html(self.ruta_archivo, header=None)[0]

        raise ValueError("Tipo de archivo no soportado")

    # ---------------------------
    # PARTICIONAR ARCHIVO
    # ---------------------------
    def particionar(self, archivo):
        """
        Devuelve dict:
        { nombre_rango : df_rango }
        """
        df_por_tabla = {}

        partes = self.df_config["ID_PARTE"].unique()

        for parte_id in partes:
            df_parte = self.df_config[self.df_config["ID_PARTE"] == parte_id]
            nombre_parte = df_parte["NOMBRE_PARTE"].iloc[0]

            # si es excel, seleccionar hoja
            if isinstance(archivo, dict):
                df_hoja = archivo[nombre_parte]
            else:
                df_hoja = archivo  # csv/txt tienen solo 1 parte

            rangos = df_parte["NOMBRE_RANGO"].unique()

            for rango in rangos:
                df_rango_conf = df_parte[df_parte["NOMBRE_RANGO"] == rango]

                fila_ini = df_rango_conf["FILA_INICIO"].iloc[0]
                col_ini = df_rango_conf["COL_INICIO"].iloc[0]
                col_fin = df_rango_conf["COL_FIN"].iloc[0] + 1

                df_extraido = df_hoja.iloc[fila_ini:, col_ini:col_fin]

                # aplicar nombres de columna
                df_extraido.columns = df_rango_conf["NOMBRE_COLUMN"].tolist()

                df_por_tabla[rango] = df_extraido

        return df_por_tabla

    # ---------------------------
    # VALIDAR TIPADO
    # ---------------------------
    def validar_tipos(self, rango, df, df_conf, id_insumo):
        if id_insumo in self.remediacion:
            return True, {}

        errores = {}

        for _, row in df_conf.iterrows():
            col = row["NOMBRE_COLUMN"]
            tipo = row["TIPO_DATO_GRAL"]

            for idx, val in df[col].items():
                try:
                    if tipo == "DATE":
                        pd.to_datetime(val)
                    elif tipo == "FLOAT":
                        float(val)
                    elif tipo == "INT":
                        int(val)
                except:
                    if col not in errores:
                        errores[col] = []
                    errores[col].append(idx)

        return (len(errores) == 0), errores

    # ---------------------------
    # CARGAR DATOS A BD
    # ---------------------------
    def cargar_bd(self, tablas_particionadas):
        logs = []

        with self.DB(self.ruta_db) as db:

            for rango, df in tablas_particionadas.items():

                df_conf = self.df_config[self.df_config["NOMBRE_RANGO"] == rango]
                id_insumo = df_conf["ID_INSUMO"].iloc[0]

                ok, errores = self.validar_tipos(rango, df, df_conf, id_insumo)

                if not ok:
                    logs.append({
                        "id_insumo": id_insumo,
                        "rango": rango,
                        "errores": errores
                    })
                    continue

                if id_insumo in self.remediacion:
                    if_exists = "replace"
                else:
                    if_exists = "append"

                db.cargar_df_tabla(df, rango, if_exists)

        return logs


