class RepoEstadoVersion:
    """
    Actualiza SIEMPRE la tabla de control de versiones
    """

    def __init__(self, ruta_db, id_insumo, version_origen, version_normalizada, fecha_datos, db_manager_cls):
        self.ruta_db = ruta_db
        self.id = id_insumo
        self.version_origen = version_origen
        self.version_normalizada = version_normalizada
        self.fecha_datos = fecha_datos
        self.DB = db_manager_cls

    def actualizar_version(self, estatus, mensaje_error):
        query = """
        REPLACE INTO ESTADO_VERSION
        (ID_INSUMO, VERSION_ACTUAL_ORIGEN, VERSION_ACTUAL_NORMALIZADA, FECHA_DATOS, ESTATUS_PROCESAMIENTO, MENSAJE_ERROR)
        VALUES (?, ?, ?, ?, ?, ?)
        """

        params = [
            self.id, 
            self.version_origen,
            self.version_normalizada,
            self.fecha_datos,
            estatus,
            mensaje_error
        ]

        with self.DB(self.ruta_db) as db:
            db.ejecutar_dml(query, params)

