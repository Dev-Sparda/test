import pandas as pd
import json
import sqlite3


class RepoCrearBase:
    """
    Esta clase recibe:
    - ruta_db: ruta del archivo SQLite
    - df_config: dataframe con la configuración del insumo (partes/rangos/columnas)
    """
    def __init__(self, ruta_db, df_config, db_manager_cls):
        self.ruta_db = ruta_db
        self.df_config = df_config
        self.DB = db_manager_cls

    def crear_tablas_insumo(self):
        """
        Crea todas las tablas que requiere el insumo según la configuración.
        Cada rango = una tabla.
        """
        rangos = self.df_config["NOMBRE_RANGO"].unique()

        with self.DB(self.ruta_db) as db:
            for rango in rangos:
                df_rango = self.df_config[self.df_config["NOMBRE_RANGO"] == rango]

                columnas_sql = []
                for _, row in df_rango.iterrows():
                    col = row["NOMBRE_COLUMN"]
                    tipo = row["TIPO_DATO_SYS"]
                    pk = "PRIMARY KEY" if row.get("KEY_COLUMN", 0) == 1 else ""
                    columnas_sql.append(f"{col} {tipo} {pk}")

                columnas_str = ", ".join(columnas_sql)
                query = f"CREATE TABLE IF NOT EXISTS {rango} ({columnas_str})"
                db.ejecutar_dml(query)

        return True


